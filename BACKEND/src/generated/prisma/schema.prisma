// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Role {
  role_id   Int    @id @default(autoincrement())
  role_text String // Isinya: 'admin', 'mentor', atau 'user_biasa'
  users     User[]

  @@map("role")
}

model User {
  user_id   Int      @id @default(autoincrement())
  role_id   Int
  name      String
  email     String   @unique
  password  String
  join_date DateTime @default(now()) @map("join_date")

  role        Role         @relation(fields: [role_id], references: [role_id])
  enrollments Enrollment[]
  reviews     Review[]
  exams       Exam[]

  @@map("user")
}

model Category {
  category_id Int     @id @default(autoincrement())
  categories  String
  classes     Class[]

  @@map("category")
}

model Periode {
  periode_id Int     @id @default(autoincrement())
  year       String
  classes    Class[]

  @@map("periode")
}

model Level {
  level_id   Int     @id @default(autoincrement())
  level_info String
  classes    Class[]

  @@map("level")
}

model Class {
  class_id Int @id @default(autoincrement())

  // 1. WAJIB DITAMBAHKAN: Kolom fisik penampung ID Relasi (semuanya pakai Int)
  category_id Int
  periode_id  Int
  level_id    Int

  title       String
  description String  @db.Text
  is_active   Boolean @default(true)

  // 2. Baris @relation di bawah ini sekarang sudah aman karena kolom di atas sudah ada & tipenya match
  category Category @relation(fields: [category_id], references: [category_id])
  periode  Periode  @relation(fields: [periode_id], references: [periode_id])
  level    Level    @relation(fields: [level_id], references: [level_id])

  materis    Materi[]
  exams      Exam[]
  reviews    Review[]
  enrollment Enrollment[]

  @@map("class")
}

model Enrollment {
  enrollment_id Int    @id @default(autoincrement())
  user_id       Int
  class_id      Int
  progress      Int    @default(0)
  role_in_class String // Kunci penting: Isinya 'mentor' jika dia pengajar, dan 'student' jika dia murid

  user  User  @relation(fields: [user_id], references: [user_id])
  class Class @relation(fields: [class_id], references: [class_id])

  @@map("enrollment")
}

model Materi {
  materi_id Int    @id @default(autoincrement())
  class_id  Int
  title     String
  content   String @db.Text
  video_url String

  class Class @relation(fields: [class_id], references: [class_id])

  @@map("materi")
}

model Exam {
  exam_id   Int     @id @default(autoincrement())
  class_id  Int
  user_id   Int
  title     String
  min_score Int     @default(60) @map("min_score")
  score     Int     @default(0)
  is_passed Boolean @default(false) @map("is_passed")

  class Class @relation(fields: [class_id], references: [class_id])
  user  User  @relation(fields: [user_id], references: [user_id])

  @@map("exams")
}

model Review {
  review_id Int    @id @default(autoincrement())
  user_id   Int
  class_id  Int
  rating    Int
  comment   String @db.Text

  user  User  @relation(fields: [user_id], references: [user_id])
  class Class @relation(fields: [class_id], references: [class_id])

  @@map("review")
}
